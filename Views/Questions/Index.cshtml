@model IEnumerable<MVCProject.Models.Question>

@{
    ViewData["Title"] = "Zarządzanie Pytaniami";
}

<h1>Index</h1>

<div class="card mb-4 bg-light border-primary">
    <div class="card-body">
        <h5 class="card-title text-primary"><i class="bi bi-filetype-json"></i> Masowy import pytań z pliku JSON</h5>
        <p class="card-text text-muted small">Wybierz plik .json zawierający tablicę obiektów pytań przypisanych do odpowiednich CourseId.</p>

        <form asp-controller="Questions" asp-action="ReadText" method="post" enctype="multipart/form-data" class="row g-3 align-items-center">
            <div class="col-auto">
                <input type="file" name="UploadedFile" class="form-control" accept=".json" required />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Importuj pytania</button>
            </div>
            <a asp-controller="Questions" asp-action="ExportToJson" class="btn btn-success">
                Pobierz eksport (.json)
            </a>
        </form>

        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success mt-3 mb-0 py-2">
                @ViewBag.SuccessMessage
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mt-3 mb-0 py-2">
                @TempData["ErrorMessage"]
            </div>
        }
    </div>
</div>

<p>
    <a asp-action="Create" class="btn btn-success">Stwórz</a>
</p>

<table class="table table-striped table-hover mt-3">
    <thead>
    <tr>
        <th>@Html.DisplayNameFor(model => model.Text)</th>
        <th>Kurs (ID)</th>
        <th>@Html.DisplayNameFor(model => model.A)</th>
        <th>@Html.DisplayNameFor(model => model.B)</th>
        <th>@Html.DisplayNameFor(model => model.C)</th>
        <th>@Html.DisplayNameFor(model => model.D)</th>
        <th>Poprawna</th>
        <th>Akcje</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td><strong>@Html.DisplayFor(modelItem => item.Text)</strong></td>
            <td>
                <span class="badge bg-secondary">ID: @Html.DisplayFor(modelItem => item.Course.Id)</span>
            </td>
            <td>@Html.DisplayFor(modelItem => item.A)</td>
            <td>@Html.DisplayFor(modelItem => item.B)</td>
            <td>@Html.DisplayFor(modelItem => item.C)</td>
            <td>@Html.DisplayFor(modelItem => item.D)</td>
            <td>
                <span class="badge bg-success">@Html.DisplayFor(modelItem => item.CorrectAnswer)</span>
            </td>
            <td>
                <div class="btn-group btn-group-sm">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>